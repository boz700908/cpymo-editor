<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CpymoEditor.ViewModels;assembly=CpymoEditor.Core"
             x:Class="CpymoEditor.Pages.AssetsPage"
             x:DataType="viewModels:AssetsViewModel"
             Title="素材"
             SemanticProperties.Description="素材库">
    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">
        <Label Text="素材库"
               FontSize="24"
               FontAttributes="Bold"
               SemanticProperties.HeadingLevel="Level1" />
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Assets}"
                        EmptyView="打开工程后，这里会按背景、立绘、音乐、音效、语音、视频和系统图片分类显示素材。"
                        SemanticProperties.Description="素材分类列表">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:AssetRowViewModel">
                    <Grid Padding="12"
                          RowDefinitions="Auto,Auto"
                          ColumnDefinitions="96,*"
                          SemanticProperties.Description="{Binding AccessibleName}">
                        <Label Text="{Binding Kind}"
                               FontAttributes="Bold"
                               VerticalOptions="Start" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding RelativePath}"
                                   FontSize="12"
                                   LineBreakMode="MiddleTruncation" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
