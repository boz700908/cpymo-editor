<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CpymoEditor.ViewModels;assembly=CpymoEditor.Core"
             x:Class="CpymoEditor.Pages.AddEventPage"
             x:DataType="viewModels:AddEventViewModel"
             Title="添加"
             SemanticProperties.Description="添加事件">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <Label Text="添加事件"
                   FontSize="24"
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />
            <CollectionView ItemsSource="{Binding Categories}"
                            SemanticProperties.Description="事件类型分类">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:AddEventCategoryViewModel">
                        <VerticalStackLayout Spacing="8" Padding="0,0,0,16">
                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   SemanticProperties.HeadingLevel="Level2" />
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Events}"
                                                 Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:AddEventTemplateViewModel">
                                        <Button Text="{Binding Name}"
                                                Command="{Binding SelectCommand}"
                                                SemanticProperties.Description="{Binding AccessibleName}" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label Text="{Binding SelectedEventName, StringFormat='已选择：{0}'}"
                   SemanticProperties.Description="{Binding SelectedEventName, StringFormat='当前选择的事件是 {0}'}" />
            <VerticalStackLayout IsVisible="{Binding IsTextEventSelected}"
                                 Spacing="8"
                                 SemanticProperties.Description="文本事件参数">
                <Label Text="说话人" />
                <Entry Text="{Binding Speaker}"
                       Placeholder="旁白可留空"
                       SemanticProperties.Description="说话人" />
                <Label Text="文本" />
                <Editor Text="{Binding Text}"
                        AutoSize="TextChanges"
                        Placeholder="输入台词或旁白文本"
                        SemanticProperties.Description="文本内容" />
                <Button Text="创建事件"
                        Command="{Binding CreateEventCommand}"
                        SemanticProperties.Description="根据当前参数创建事件" />
            </VerticalStackLayout>
            <Label Text="{Binding StatusMessage}"
                   SemanticProperties.Description="{Binding StatusMessage}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
