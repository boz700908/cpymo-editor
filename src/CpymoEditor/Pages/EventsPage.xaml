<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CpymoEditor.ViewModels;assembly=CpymoEditor.Core"
             x:Class="CpymoEditor.Pages.EventsPage"
             x:DataType="viewModels:EventsViewModel"
             Title="事件"
             SemanticProperties.Description="事件列表">
    <ContentPage.BindingContext>
        <viewModels:EventsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">
        <Label Text="事件"
               FontSize="24"
               FontAttributes="Bold"
               SemanticProperties.HeadingLevel="Level1" />
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Events}"
                        EmptyView="打开脚本文件后，这里会分页显示线性事件列表。"
                        SemanticProperties.Description="分页事件列表">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:EventRowViewModel">
                    <Grid Padding="8"
                          RowDefinitions="Auto,Auto"
                          ColumnDefinitions="*,Auto"
                          SemanticProperties.Description="{Binding AccessibleName}">
                        <Label Text="{Binding Kind}"
                               FontAttributes="Bold" />
                        <Label Grid.Row="1"
                               Text="{Binding Summary}" />
                        <Button Grid.Column="1"
                                Grid.RowSpan="2"
                                Text="选择"
                                Command="{Binding SelectCommand}"
                                SemanticProperties.Description="{Binding AccessibleName, StringFormat='选择事件：{0}'}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <HorizontalStackLayout Grid.Row="2" Spacing="8">
            <Button Text="上一页"
                    Command="{Binding PreviousPageCommand}"
                    SemanticProperties.Description="上一页事件" />
            <Button Text="下一页"
                    Command="{Binding NextPageCommand}"
                    SemanticProperties.Description="下一页事件" />
            <Button Text="跳转"
                    SemanticProperties.Description="跳转到标签或页码" />
            <Button Text="复制"
                    Command="{Binding DuplicateSelectedCommand}"
                    SemanticProperties.Description="复制当前选择的事件" />
            <Button Text="删除"
                    Command="{Binding DeleteSelectedCommand}"
                    SemanticProperties.Description="删除当前选择的事件" />
            <Button Text="上移"
                    Command="{Binding MoveSelectedUpCommand}"
                    SemanticProperties.Description="上移当前选择的事件" />
            <Button Text="下移"
                    Command="{Binding MoveSelectedDownCommand}"
                    SemanticProperties.Description="下移当前选择的事件" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
